# Production build config (used by `vite build`, i.e. deployed vibe app).
# Vite loads .env.production AFTER .env.local, so these OVERRIDE the local dev
# values — critical: it keeps the dev bearer token in .env.local OUT of the
# public production bundle. A deployed vibe app runs with dev mode off and talks
# to its own origin via the Vibe SDK (connectors / vibe-db), not @facilio/api.
VITE_DEV_MODE=false
VITE_FACILIO_API_BASE_URL=
VITE_FACILIO_TOKEN=
